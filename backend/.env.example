SECRET_KEY=CHANGE_ME_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=240

POSTGRES_SERVER=db
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=file_registry

FILE_STORAGE_BACKEND=local
FILE_STORAGE_PATH=/data/files

# Blockchain (optional for first run, but required for /api/blockchain/*)
WEB3_PROVIDER_URL=http://blockchain:8545
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
CONTRACT_OWNER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
CONTRACT_OWNER_ADDRESS=0xYOUR_ADDRESS
CHAIN_ID=31337

BACKEND_CORS_ORIGINS=["http://localhost:5173"]

